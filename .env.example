# ado-mcp environment configuration.
# Copy to .env and fill in your values:  cp .env.example .env
# (.env is gitignored; never commit real tokens.)

# --- Required: Azure DevOps ---

# Organization URL, e.g. https://dev.azure.com/myorg
ADO_ORG_URL=https://dev.azure.com/myorg

# Personal Access Token (Basic auth). Create one at:
# https://dev.azure.com/<org>/_usersSettings/tokens
ADO_PAT=

# --- Optional: 7pace Timetracker ---
# Both must be set to enable the 7pace tools.

# 7pace account name; builds https://<org>.timehub.7pace.com/api
SEVENPACE_ORG=

# 7pace bearer token (Settings -> Reporting and API -> Create New Token)
SEVENPACE_TOKEN=

# --- Optional: server behavior ---

# Comma-separated toolset names to enable, or "all" (default).
# e.g. ADO_TOOLSETS=core,wit,git,logs
ADO_TOOLSETS=all

# "true" exposes only read-only tools (hides every mutating tool).
ADO_READONLY=false

# Override the application directory (default: <user config dir>/ado-mcp,
# e.g. ~/.config/ado-mcp). The work-log SQLite database lives in data/ within it.
# ADO_MCP_HOME=
